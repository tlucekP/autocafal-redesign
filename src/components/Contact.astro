---
interface Props {
  phone: string;
  phoneHref: string;
  email: string;
  emailHref: string;
  address: string;
  hours: string;
  mapGoogle: string;
  mapMapycz: string;
  formEndpoint: string;
}

const { phone, phoneHref, email, emailHref, address, hours, mapGoogle, mapMapycz, formEndpoint } = Astro.props;
const mapEmbedUrl = `https://www.google.com/maps?q=${encodeURIComponent(address)}&output=embed`;
const mapDirectionUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}`;
---

<section id="kontakt" class="section-padding border-t border-slate-200/80">
  <div class="container-custom grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="card p-6 sm:p-8">
      <h2 class="text-3xl font-bold tracking-tight text-slate-950">Kontakt</h2>
      <dl class="mt-6 space-y-4 text-sm">
        <div>
          <dt class="font-semibold text-slate-900">Telefon</dt>
          <dd><a class="text-slate-700 hover:text-slate-900" href={phoneHref}>{phone}</a></dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900">E-mail</dt>
          <dd><a class="text-slate-700 hover:text-slate-900" href={emailHref}>{email}</a></dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900">Adresa</dt>
          <dd class="text-slate-700">{address}</dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900">Otevírací doba</dt>
          <dd class="text-slate-700">{hours}</dd>
        </div>
      </dl>
      <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <div class="relative h-64 w-full">
          <iframe
            title="Mapa Autoservis Cafal"
            src={mapEmbedUrl}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-full w-full border-0"
          ></iframe>
          <div class="absolute left-3 top-3 rounded-xl bg-white/95 px-3 py-2 shadow-sm">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xl font-semibold text-slate-900">1104</p>
                <p class="text-sm leading-tight text-slate-700">{address}, Česko</p>
              </div>
              <div class="flex items-center gap-2">
                <a href={mapGoogle} target="_blank" rel="noreferrer" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-300 bg-white text-lg font-semibold text-slate-700 hover:bg-slate-100" aria-label="Otevřít v Google Maps">↗</a>
                <a href={mapDirectionUrl} target="_blank" rel="noreferrer" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-300 bg-white text-lg font-semibold text-slate-700 hover:bg-slate-100" aria-label="Navigovat">➤</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card p-6 sm:p-8">
      <h3 class="text-xl font-bold text-slate-950">Poptávkový formulář</h3>
      <form action={formEndpoint} method="post" class="mt-5 space-y-4" data-contact-form>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="name" class="mb-1 block text-sm font-medium text-slate-800">Jméno</label>
            <input id="name" name="name" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
          </div>
          <div>
            <label for="surname" class="mb-1 block text-sm font-medium text-slate-800">Příjmení</label>
            <input id="surname" name="surname" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="phone" class="mb-1 block text-sm font-medium text-slate-800">Telefon</label>
            <input id="phone" name="phone" type="tel" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
          </div>
          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-slate-800">E-mail</label>
            <input id="email" name="email" type="email" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="vehicleBrand" class="mb-1 block text-sm font-medium text-slate-800">Značka vozidla</label>
            <input id="vehicleBrand" name="vehicleBrand" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
          </div>
          <div>
            <label for="vin" class="mb-1 block text-sm font-medium text-slate-800">VIN kód</label>
            <input id="vin" name="vin" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
          </div>
        </div>
        <div>
          <label for="message" class="mb-1 block text-sm font-medium text-slate-800">Zpráva</label>
          <textarea id="message" name="message" rows="5" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full sm:w-auto" data-submit-button>Odeslat poptávku</button>
        <p class="text-sm text-slate-600" data-form-status></p>
      </form>
    </div>
  </div>

  <script>
    const form = document.querySelector('[data-contact-form]');
    const status = document.querySelector('[data-form-status]');
    const submit = document.querySelector('[data-submit-button]');

    if (form && status && submit) {
      const endpoint = form.getAttribute('action');

      if (!endpoint || endpoint.includes('your-form-id')) {
        status.textContent = 'Doplňte PUBLIC_FORM_ENDPOINT v .env.';
      }

      form.addEventListener('submit', (event) => {
        submit.setAttribute('disabled', 'true');
        submit.textContent = 'Odesílám...';

        if (!endpoint || endpoint.includes('your-form-id')) {
          event.preventDefault();
          status.textContent = 'Formulář není nakonfigurovaný.';
          submit.removeAttribute('disabled');
          submit.textContent = 'Odeslat poptávku';
        }
      });
    }
  </script>
</section>
