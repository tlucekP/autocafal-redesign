---
interface Props {
  phone: string;
  phoneHref: string;
  email: string;
  emailHref: string;
  address: string;
  hours: string;
  mapGoogle: string;
  mapMapycz: string;
  formEndpoint: string;
}

const { phone, phoneHref, email, emailHref, address, hours, mapGoogle, mapMapycz, formEndpoint } = Astro.props;
---

<section id="kontakt" class="section-padding border-t border-slate-200/80">
  <div class="container-custom grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="card p-6 sm:p-8">
      <h2 class="text-3xl font-bold tracking-tight text-slate-950">Kontakt</h2>
      <dl class="mt-6 space-y-4 text-sm">
        <div>
          <dt class="font-semibold text-slate-900">Telefon</dt>
          <dd><a class="text-slate-700 hover:text-slate-900" href={phoneHref}>{phone}</a></dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900">E-mail</dt>
          <dd><a class="text-slate-700 hover:text-slate-900" href={emailHref}>{email}</a></dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900">Adresa</dt>
          <dd class="text-slate-700">{address}</dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-900">Otevírací doba</dt>
          <dd class="text-slate-700">{hours}</dd>
        </div>
      </dl>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href={mapGoogle} target="_blank" rel="noreferrer" class="btn-secondary">Google Maps</a>
        <a href={mapMapycz} target="_blank" rel="noreferrer" class="btn-secondary">Mapy.cz</a>
      </div>
    </div>

    <div class="card p-6 sm:p-8">
      <h3 class="text-xl font-bold text-slate-950">Poptávkový formulář</h3>
      <form action={formEndpoint} method="post" class="mt-5 space-y-4" data-contact-form>
        <div>
          <label for="name" class="mb-1 block text-sm font-medium text-slate-800">Jméno</label>
          <input id="name" name="name" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
        </div>
        <div>
          <label for="contact" class="mb-1 block text-sm font-medium text-slate-800">Telefon nebo e-mail</label>
          <input id="contact" name="contact" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm" />
        </div>
        <div>
          <label for="message" class="mb-1 block text-sm font-medium text-slate-800">Zpráva</label>
          <textarea id="message" name="message" rows="5" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full sm:w-auto" data-submit-button>Odeslat poptávku</button>
        <p class="text-sm text-slate-600" data-form-status></p>
      </form>
    </div>
  </div>

  <script>
    const form = document.querySelector('[data-contact-form]');
    const status = document.querySelector('[data-form-status]');
    const submit = document.querySelector('[data-submit-button]');

    if (form && status && submit) {
      const endpoint = form.getAttribute('action');

      if (!endpoint || endpoint.includes('your-form-id')) {
        status.textContent = 'Doplňte PUBLIC_FORM_ENDPOINT v .env.';
      }

      form.addEventListener('submit', (event) => {
        submit.setAttribute('disabled', 'true');
        submit.textContent = 'Odesílám...';

        if (!endpoint || endpoint.includes('your-form-id')) {
          event.preventDefault();
          status.textContent = 'Formulář není nakonfigurovaný.';
          submit.removeAttribute('disabled');
          submit.textContent = 'Odeslat poptávku';
        }
      });
    }
  </script>
</section>
