---
interface PricingItem {
  name: string;
  price: string;
}

interface PricingSection {
  section: string;
  items: PricingItem[];
}

interface Props {
  sections: PricingSection[];
}

const { sections } = Astro.props;
---

<section id="cenik" class="section-padding border-t border-slate-200/80">
  <div class="container-custom">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-950">Ceník</h2>
      <p class="mt-3 text-slate-600">Orientační ceník služeb.</p>
    </div>
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {sections.map((section) => (
        <article class="card overflow-hidden">
          <h3 class="border-b border-slate-200 bg-slate-50 px-5 py-4 text-base font-semibold text-slate-900">{section.section}</h3>
          <ul class="divide-y divide-slate-100">
            {section.items.map((item) => (
              <li class="flex items-center justify-between gap-4 px-5 py-3 text-sm">
                <span class="text-slate-700">{item.name}</span>
                <span class="font-semibold text-slate-900">{item.price}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
