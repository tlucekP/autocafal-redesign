---
interface PricingItem {
  name: string;
  description?: string;
  price: string;
}

interface PricingSection {
  section: string;
  items: PricingItem[];
}

interface Props {
  sections: PricingSection[];
}

const { sections } = Astro.props;
const items = sections.flatMap((section) => section.items);
---

<section id="cenik" class="section-padding border-t border-slate-200/80">
  <div class="container-custom">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-950">Ceník</h2>
      <div class="mt-4 h-1 w-16 bg-yellow-400"></div>
      <p class="mt-3 text-slate-600">Orientační ceník služeb.</p>
    </div>

    <div class="mt-10 space-y-7">
      {items.map((item) => (
        <article class="grid gap-3 border-b border-slate-200 pb-6 sm:grid-cols-[1fr_auto] sm:items-start">
          <div>
            <h3 class="text-2xl font-semibold tracking-tight text-slate-950">{item.name}</h3>
            {item.description && <p class="mt-2 text-lg leading-relaxed text-slate-700">{item.description}</p>}
          </div>
          <p class="text-2xl font-bold text-slate-950 sm:pt-1">{item.price}</p>
        </article>
      ))}
    </div>

    <div class="mt-8 border-t-2 border-yellow-400 pt-4">
      <p class="text-xl font-semibold text-slate-900">Ceny jsou uvedené včetně DPH.</p>
    </div>
  </div>
</section>
