---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  businessName: string;
  phoneHref: string;
  phone: string;
  navItems: NavItem[];
}

const { businessName, phoneHref, phone, navItems } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/95 backdrop-blur">
  <div class="container-custom flex h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="#hero" class="text-sm font-bold tracking-tight text-slate-900">{businessName}</a>
    <nav class="hidden items-center gap-6 md:flex" aria-label="Hlavni navigace">
      {navItems.map((item) => (
        <a href={item.href} class="text-sm font-medium text-slate-600 transition hover:text-slate-900">{item.label}</a>
      ))}
    </nav>
    <a href={phoneHref} class="hidden rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-900 transition hover:bg-slate-100 md:inline-flex">{phone}</a>
    <a href="#kontakt" class="inline-flex rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-900 md:hidden">Kontakt</a>
  </div>
</header>
